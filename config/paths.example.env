# Copy to config/paths.env and edit for your system.
# config/paths.env is ignored by Git.

export PROJECT="/path/to/dual-conditioning"
export SANDBOX="/path/to/diffsbdd_container_or_sandbox"
export CHECKPOINT="${PROJECT}/artifacts/checkpoints/crossdocked_fullatom_cond.ckpt"

# OpenMM/PoseCheck validation environment (only needed for restrained relaxation).
export SIF="/path/to/openmm_validation.sif"
